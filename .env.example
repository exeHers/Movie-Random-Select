# TMDB (required)
TMDB_API_KEY=

# Optional: shared database for all phones (PostgreSQL).
# Local dev: leave unset → uses data/movie_night.sqlite on this machine only.
# Hosted: Neon, Supabase, Railway, Fly Postgres, etc.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# Optional: canonical link shown in the app (your deployed URL). If unset, the
# current browser origin is used when you tap "Copy app link".
# PUBLIC_BASE_URL=https://movies.yourfamily.com

# Trusted Web Activity (Android Studio APK via Bubblewrap). Required for
# /.well-known/assetlinks.json — use your release keystore SHA-256 (keytool).
# ANDROID_TWA_PACKAGE=com.yourfamily.movienight
# ANDROID_TWA_SHA256=AA:BB:CC:...   # one per line or comma-separated if multiple
